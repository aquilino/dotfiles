    "clock": {
        "interval": 10,
        "format-alt": " {:%e %b %Y}", // Icon: calendar-alt
        "format": "{:%H:%M}",
        "tooltip-format": "  {:%A, %e %B %Y}"
    },

   "custom/updates": {
        "format": "{}",
        "exec": "/home/h1dr0/.config/waybar/themes/scripts/update-sys",
        "on-click": "/home/h1dr0/.config/waybar/themes/scripts/update-sys update",
        "interval": 300,
        "tooltip": true
    },
